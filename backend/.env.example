# Copy to .env and fill in.

# --- LLM: Nebius Token Factory (OpenAI-compatible) ---
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1
NEBIUS_API_KEY=...
# Any tool-calling model from the catalogue:
# https://docs.tokenfactory.nebius.com/ai-models-inference/overview
NEBIUS_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct

# Optional fallback (used only if NEBIUS_API_KEY is unset).
# ANTHROPIC_API_KEY=sk-ant-...
# MODEL=anthropic:claude-sonnet-4-6

# MongoDB connection for the LangGraph checkpointer (threads + state).
# Matches the docker-compose.yml service in the project root.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=deep_coding_agent

# Where cloned / linked repos live (default clone directory).
WORKSPACES_DIR=./workspaces

# --- Optional: per-repo graphify knowledge graph ---
# Requires `pip install "graphifyy[mcp]"` in this environment.
ENABLE_GRAPHIFY=false
# Backend for extracting docs/PDFs (code is parsed locally, no key). e.g. openai
# GRAPHIFY_EXTRACT_BACKEND=openai

# Comma-separated allowed origins for the frontend.
CORS_ORIGINS=http://localhost:3000
